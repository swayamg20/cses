{
  "version": "2.0.0",
  "tasks": [
    {
      "label": "C++ Build & Run (with I/O)",
      "type": "shell",
      "command": "g++ -std=c++17 -O2 -Wall -o ${fileDirname}/${fileBasenameNoExtension} ${file} && ${fileDirname}/${fileBasenameNoExtension} < ${fileDirname}/txt/input.txt > ${fileDirname}/txt/output.txt",
      "group": {
        "kind": "build",
        "isDefault": true
      },
      "presentation": {
        "reveal": "always",
        "panel": "shared",
        "clear": true
      },
      "problemMatcher": "$gcc"
    },
    {
      "label": "C++ Build & Run (terminal)",
      "type": "shell",
      "command": "g++ -std=c++17 -O2 -Wall -o ${fileDirname}/${fileBasenameNoExtension} ${file} && ${fileDirname}/${fileBasenameNoExtension}",
      "group": "build",
      "presentation": {
        "reveal": "always",
        "panel": "shared",
        "clear": true
      },
      "problemMatcher": "$gcc"
    }
  ]
}
